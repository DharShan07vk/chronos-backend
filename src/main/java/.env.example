# Database
# Local example: jdbc:postgresql://localhost:5432/chronos
# Production example: jdbc:postgresql://<db-host>:5432/<db-name>?sslmode=require
DB_URI=jdbc:postgresql://localhost:5432/chronos
DB_USERNAME=postgres
DB_PASSWORD=change_me

# JWT
# Use a long random secret in production (at least 32 chars)
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
# Token expiration in milliseconds (24h)
JWT_EXPIRE=86400000

# CORS
# Comma-separated list of allowed frontend origins
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:1357,https://your-frontend-domain.com

# Media cache max age in seconds (1 year)
APP_MEDIA_CACHE_MAX_AGE_SECONDS=31536000